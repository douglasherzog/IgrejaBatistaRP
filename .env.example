DATABASE_URL=postgresql://usuario:senha@localhost:5432/igrejadb
SECRET_KEY=troque-por-uma-chave-secreta-longa-e-aleatoria
TOTP_ISSUER=IgrejaBatistaNovaVida
ADMIN_EMAIL=admin@suaigreja.com.br

# Configuração do provedor de WhatsApp
# Opções: webhook (whatsapp-web.js local), meta-cloud (oficial), evolution-api (open-source), z-api (pago), simulacao
WHATSAPP_PROVIDER=webhook

# Webhook para servidor WhatsApp local (whatsapp-web.js)
WHATSAPP_WEBHOOK_URL=http://localhost:3001/send-message

# Meta Cloud API (WhatsApp Oficial) - até 1.000 conversas/mês gratuitas
META_API_VERSION=v18.0
META_PHONE_NUMBER_ID=SEU_PHONE_NUMBER_ID
META_ACCESS_TOKEN=SEU_ACCESS_TOKEN

# Evolution API (open-source, self-hosted e gratuita)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_INSTANCE_NAME=ibinovi
EVOLUTION_API_KEY=ibinovi_global_apikey

# Z-API (pago) - descomente se for usar
# Z_API_URL=https://api.z-api.io/instances/SUA_INSTANCE/token/SEU_TOKEN
# Z_API_KEY=SEU_TOKEN

# Número do WhatsApp da igreja (somente dígitos, com DDI 55)
WHATSAPP_PHONE_NUMBER=5551999999999
